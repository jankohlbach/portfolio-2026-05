3323 143.941 0.85351L145.815 0.541256V15.467C145.836 16.0499 145.94 16.4454 146.502 16.5703L146.585 16.8409H143.483L143.567 16.5703C144.129 16.4454 144.233 16.0499 144.254 15.467V9.38847H134.615V12.6984C134.636 13.2812 134.74 13.6768 135.302 13.8017L135.386 14.0723H132.284Z"
          fill="currentColor"></path>
      </svg>
    </div>
  </div>
</footer>

<style lang="scss">
  footer {
    padding-top: var(--s-sections);
    padding-bottom: to-rem(32);
  }

  .cta {
    grid-column: 1 / span 12;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: clamp-fluid(32, 64);

    .text {
      font-size: var(--fs-3);
      font-weight: var(--fw-semibold);
      line-height: 1.1;
      text-transform: uppercase;
      white-space: pre-line;
    }
  }

  .links {
    grid-column: 1 / span 12;
    margin-top: clamp-fluid(64, 128);
    display: flex;
    gap: clamp-fluid(16, 32);

    a {
      text-decoration: none;
    }

    nav {
      width: 50%;
    }

    ul {
      display: flex;
      flex-direction: column;
      gap: to-rem(8);
      list-style: none;
    }
  }

  .bottom {
    margin-top: 20vh;

    .copyright {
      margin-right: clamp-fluid(0, 16);
      margin-bottom: clamp-fluid(16, 32);
      text-align: right;

      .sign {
        font-family: var(--ff-secondary);
        font-size: 1.25em;
      }
    }
  }

  @media (width >= 560px) {
    .links {
      grid-column: 1 / span 8;
    }
  }

  @media (width >= 1024px) {
    .cta {
      grid-column: 1 / 9;
    }

    .links {
      grid-column: 9 / 13;
      margin-top: 0;
    }

    .bottom {
      margin-top: 35vh;
    }
  }

  @media (width >= 1280px) {
    .cta {
      grid-column: 1 / 10;
    }

    .links {
      grid-column: 10 / 13;
    }
  }
</style>
