---
import { getEntries } from 'astro:content';

import { footer } from '@content/globals';

import Button from '@components/blocks/Button.astro';
import LinkWithIndicator from '@components/blocks/LinkWithIndicator.astro';

const currentYear = new Date().getFullYear();

const linksInternal = await getEntries(
  footer.linksInternal.map((item) => item.link),
);
---

<script>
  const copyright = document.querySelector('[data-js="footer-copyright-year"]');
  if (copyright) copyright.textContent = `${new Date().getFullYear()}`;
</script>

<footer>
  <div class="container">
    <div class="grid">
      <div class="cta">
        <p class="text">{footer.ctaText}</p>
        <Button title={footer.cta.title} link={footer.cta.link} />
      </div>
      <div class="links">
        <nav aria-label="Sitemap">
          <ul>
            {
              linksInternal.map((link) => (
                <li>
                  <LinkWithIndicator
                    title={link.data.title}
                    link={`/${link.data.slug}`}
                  />
                </li>
              ))
            }
          </ul>
        </nav>
        <nav aria-label="Social links">
          <ul>
            {
              footer.linksSocial.map((link) => (
                <li>
                  <LinkWithIndicator
                    title={link.title}
                    link={link.link}
                    target="_blank"
                    rel="noopener noreferrer"
                  />
                </li>
              ))
            }
          </ul>
        </nav>
      </div>
    </div>
    <div class="bottom">
      <div class="copyright text-small-caps">
        <span class="sign">© </span><span
          class="year"
          data-js="footer-copyright-year">{currentYear}</span
        >
      </div>
