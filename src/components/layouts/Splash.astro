<script>
  import { gsap } from 'gsap';

  import { scrollStop, scrollStart } from '@scripts/scroll';

  const splash: HTMLElement | null =
    document.querySelector('[data-js="splash"]');
  const splashRow: HTMLElement | null = document.querySelector(
    '[data-js="splash-row"]',
  );
  const splashPaths: NodeListOf<SVGPathElement> = document.querySelectorAll(
    '[data-js="splash-path"]',
  );
  const splashTexts: NodeListOf<HTMLElement> = document.querySelectorAll(
    '[data-js="splash-text"]',
  );

  const mm = gsap.matchMedia();

  window.addEventListener('load', () => {
    if (!sessionStorage.getItem('splash:played') && splash) {
      scrollStop();

      // TODO: reduced motion
      mm.add(
        {
          isMobile: '(max-width: 1023px)',
          isDesktopSmall: '(min-width: 1024px) and (max-width: 1279px)',
          isDesktopLarge: '(min-width: 1280px)',
        },
        (context) => {
          const { isMobile, isDesktopLarge } = context.conditions || {
            isMobile: true,
            isDesktopLarge: false,
          };

          const tl = gsap.timeline({
            delay: 0.2,
            defaults: { duration: 1, ease: 'power4.inOut' },
          });

          tl.fromTo(
            splashPaths,
            { strokeDashoffset: 1 },
            {
              strokeDashoffset: 0,
              autoRound: false,
              stagger: 0.1,
            },
          ).fromTo(
            splashTexts,
            { autoAlpha: 0 },
            {
              autoAlpha: 1,
              stagger: 0.1,
            },
            '<0.5',
          );

          if (!isMobile) {
            tl.fromTo(
              splashRow,
              { gridTemplateColumns: '1fr 2fr 1fr' },
              {
                gridTemplateColumns: isDesktopLarge
                  ? '1fr 4fr 1fr'
                  : '1fr 3fr 1fr',
              },
              '>-0.5',
            );
          } else {
            tl.fromTo(
              splashRow,
              { gridTemplateRows: '1fr 3fr 1fr' },
              {
                gridTemplateRows: '1fr 5fr 1fr',
              },
              '>-0.5',
            );
          }

          tl.fromTo(
            splash,
            { autoAlpha: 1 },
            {
              autoAlpha: 0,
            },
          )
            .call(
              () => {
                window.dispatchEvent(new Event('splash:done'));
              },
              [],
              '>-0.2',
            )
            .call(() => {
              scrollStart();
              sessionStorage.setItem('splash:played', 'true');
            });
        },
      );
    } else {
      window.dispatchEvent(new Event('splash:done'));
    }
  });

  window.addEventListener('splash:done', () => {
    document.querySelectorAll('[data-inview-manual]').forEach((el) => {
      el.classList.add('inview');
    });
  });
</script>

