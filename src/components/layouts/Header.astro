---
import { getEntries } from 'astro:content';

import { header, footer } from '@content/globals';

import Button from '@components/blocks/Button.astro';
import LinkWithIndicator from '@components/blocks/LinkWithIndicator.astro';

const navLinks = await getEntries(header.links.map((item) => item.link));
const menuLinks = await getEntries(
  footer.linksInternal.map((item) => item.link),
);
---

<script>
  import { scrollStart, scrollStop } from '@scripts/scroll';

  const menu = document.querySelector('[data-js="menu"]');
  const menuTriggerOpen = document.querySelector(
    '[data-js="menu-trigger-open"]',
  );
  const menuTriggerClose = document.querySelector(
    '[data-js="menu-trigger-close"]',
  );

  menuTriggerOpen?.addEventListener('click', () => {
    scrollStop();
    menu?.classList.add('is-active');
  });

  menuTriggerClose?.addEventListener('click', () => {
    scrollStart();
    menu?.classList.remove('is-active');
  });
</script>

<header>
  <div class="container">
    <div class="inner">
      <a class="logo" href="/" aria-label="Home">
        <svg viewBox="0 0 161 18" fill="none" aria-hidden="true">
          <path
            d="M-0.000437483 11.7593H3.21556C3.38356 13.4633 4.10356 14.4713 5.56756 14.4713C7.07956 14.4713 7.94356 13.2953 7.94356 11.3273V0.479316H11.1596V11.0873C11.1596 14.8313 9.02356 17.1593 5.56756 17.1593C2.23156 17.1593 0.215563 15.0713 -0.000437483 11.7593ZM23.7918 16.7993L22.5438 13.4153H15.5838L14.3358 16.7993H11.0958L17.2398 0.479316H21.0558L27.1998 16.7993H23.7918ZM18.5838 5.32732L16.5198 10.9193H21.6078L19.5438 5.32732L19.0638 3.64732L18.5838 5.32732ZM27.9033 16.7993V0.479316H31.3113L37.3593 10.1753L38.4873 12.4073L38.3673 0.479316H41.5833V16.7993H38.1993L32.1513 7.12732L30.9993 4.84732L31.1433 16.7993H27.9033ZM53.1543 16.7993L47.0341 9.55501L45.3895 11.72V15.4254C45.4104 16.0083 45.5144 16.4038 46.0765 16.5287L46.1598 16.7993H43.058L43.1413 16.5287C43.7034 16.4038 43.8074 16.0083 43.8283 15.4254V3.53891C43.8283 2.31071 43.8283 1.29068 43.516 0.811884L45.3895 0.49963V10.2836L49.6987 4.57976C50.906 2.99767 51.4473 1.51966 51.6138 0.49963H53.9245L48.0333 8.24354L54.4866 15.8834C54.8613 16.3205 55.1111 16.4662 55.3817 16.5287L55.465 16.7993H53.1543ZM63.4725 17.2573C59.3299 17.2573 55.3747 13.656 55.3747 8.61825C55.3747 3.58054 59.3299 2.37823e-05 63.4725 2.37823e-05C68.2604 2.37823e-05 71.5911 3.93443 71.5911 8.61825C71.5911 13.3021 68.2604 17.2573 63.4725 17.2573ZM57.1441 8.61825C57.1441 12.4902 59.3715 16.4038 63.4725 16.4038C67.5734 16.4038 69.8217 12.4902 69.8217 8.61825C69.8217 4.74629 67.5734 0.832703 63.4725 0.832703C59.3715 0.832703 57.1441 4.74629 57.1441 8.61825ZM73.3622 16.7993L73.4455 16.5287C74.0076 16.4038 74.1116 16.0083 74.1325 15.4254V3.53891C74.1325 2.31071 74.1325 1.29068 73.8202 0.811884L75.6937 0.49963V8.51416H85.332V3.53891C85.332 2.31071 85.332 1.29068 85.0197 0.811884L86.8933 0.49963V15.4254C86.9141 16.0083 87.0182 16.4038 87.5802 16.5287L87.6635 16.7993H84.5618L84.645 16.5287C85.2071 16.4038 85.3112 16.0083 85.332 15.4254V9.34684H75.6937V15.4254C75.7146 16.0083 75.8186 16.4038 76.3807 16.5287L76.464 16.7993H73.3622ZM98.9239 16.7