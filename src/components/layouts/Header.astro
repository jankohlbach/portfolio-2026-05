945L157.028 16.5287C157.59 16.4038 157.694 16.0083 157.715 15.4254V9.34684H148.077V15.4254C148.098 16.0083 148.202 16.4038 148.764 16.5287L148.847 16.7993H145.746Z"
            fill="currentColor"></path>
        </svg>
      </a>
      <nav class="nav" aria-label="Primary navigation">
        <ul>
          {
            navLinks.map((link) => (
              <li>
                <LinkWithIndicator
                  title={link.data.title}
                  link={`/${link.data.slug}`}
                  indicatorPosition="bottom"
                />
              </li>
            ))
          }
        </ul>
      </nav>
      <div class="cta">
        <Button title={header.cta.title} link={header.cta.link} />
      </div>
      <button class="menu-trigger" data-js="menu-trigger-open">
        <Button title="Menu" type="span" />
      </button>
    </div>
  </div>
</header>
<div class="menu" data-js="menu">
  <div class="menu-inner">
    <button class="close-button" data-js="menu-trigger-close">
      <Button title="Close" type="span" />
    </button>
    <nav class="menu-nav" aria-label="Primary navigation in menu">
      <ul>
        <li>
          <LinkWithIndicator title="Home" link="/" size="large" />
        </li>
        {
          menuLinks.map((link) => (
            <li>
              <LinkWithIndicator
                title={link.data.title}
                link={`/${link.data.slug}`}
                size="large"
              />
            </li>
          ))
        }
      </ul>
    </nav>
    <div class="menu-cta">
      <Button title={header.cta.title} link={header.cta.link} size="large" />
    </div>
  </div>
</div>

<style lang="scss">
  header {
    padding-block: clamp-fluid(24, 32);
  }

  .inner {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    align-items: center;
    justify-items: start;
  }

  a {
    text-decoration: none;
  }

  .logo {
    display: block;
    width: clamp-fluid(176, 256);
  }

  .nav {
    display: none;
    margin-inline: auto;

    ul {
      display: flex;
      gap: to-rem(24);
      list-style: none;
    }
  }

  .cta {
    display: none;
    margin-left: auto;
  }

  .menu-trigger {
    grid-column: 3 / 4;
    margin-left: auto;
  }

  .menu {
    position: fixed;
    inset: 0;
    z-index: var(--zi-menu);
    padding: var(--grid-margin);
    backdrop-filter: blur(12px);
    color: var(--c-dark);
    opacity: 0;
    visibility: hidden;
    transition:
      opacity 0.3s var(--ease-smooth),
      visibility 0.3s var(--ease-smooth);

    &.is-active {
      opacity: 1;
      visibility: visible;
    }

    .menu-inner {
      display: flex;
      flex-direction: column;
      align-items: flex-start;
      width: 100%;
      height: 100%;
      padding: calc(var(--grid-margin) * 1.5);
      background-color: var(--c-primary);
      border-radius: to-rem(12);
    }

    .close-button {
      align-self: flex-end;
    }

    .menu-nav {
      margin-top: auto;

      ul {
        display: flex;
        flex-direction: column;
        list-style: none;
      }
    }

    .menu-cta {
      margin-top: clamp-fluid(64, 128);
    }
  }

  @media (width >= 960px) {
    .nav {
      display: block;
    }

    .cta {
      display: block;
    }

    .menu-trigger {
      display: none;
    }
  }
</style>
